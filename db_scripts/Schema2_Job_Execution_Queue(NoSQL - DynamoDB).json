{
  "metadata": {
    "database": "job_execution_db (DynamoDB)",
    "service": "Job Orchestrator & Job Runner",
    "primaryUseCases": "UC 2.1, UC 2.3 (execution data)"
  },
  "tables": [
    {
      "tableName": "ExecutionQueue",
      "description": "Time-series with TTL",
      "keySchema": [
        {
          "attributeName": "queueId",
          "keyType": "HASH",
          "description": "Partition key: UUID"
        },
        {
          "attributeName": "scheduledFor",
          "keyType": "RANGE",
          "description": "Sort key: ISO timestamp"
        }
      ],
      "globalSecondaryIndexes": [
        {
          "indexName": "PendingExecutionsIndex",
          "keySchema": [
            {
              "attributeName": "queueStatus",
              "keyType": "HASH",
              "description": "e.g. pending"
            },
            {
              "attributeName": "priority",
              "keyType": "RANGE",
              "description": "1-10 ascending"
            }
          ],
          "projection": {
            "projectionType": "INCLUDE",
            "nonKeyAttributes": [
              "jobId",
              "scheduleId",
              "scheduledFor",
              "executionContext"
            ]
          }
        },
        {
          "indexName": "WorkerAssignmentsIndex",
          "keySchema": [
            { "attributeName": "assignedWorkerId", "keyType": "HASH" },
            { "attributeName": "assignedAt", "keyType": "RANGE" }
          ]
        },
        {
          "indexName": "JobExecutionsIndex",
          "keySchema": [
            { "attributeName": "jobId", "keyType": "HASH" },
            { "attributeName": "scheduledFor", "keyType": "RANGE" }
          ],
          "projection": {
            "projectionType": "ALL"
          }
        }
      ],
      "attributes": {
        "queueId": { "type": "S", "description": "UUID" },
        "jobId": { "type": "S", "description": "Reference to SQL job_definitions.job_id" },
        "scheduleId": { "type": "S" },
        "scheduledFor": { "type": "S", "description": "ISO timestamp" },
        "queueStatus": {
          "type": "S",
          "description": "pending, assigned, running, completed, failed, cancelled"
        },
        "priority": { "type": "N", "description": "1-10" },
        "retryCount": { "type": "N" },
        "maxRetries": { "type": "N" },
        "executionContext": {
          "type": "M",
          "description": "Snapshot at queue time",
          "attributes": {
            "parameters": { "type": "M", "description": "Map of parameter values" },
            "environment": { "type": "S", "description": "production, staging" },
            "triggerSource": { "type": "S", "description": "schedule, manual, api" },
            "userId": { "type": "S" }
          }
        },
        "assignedWorkerId": { "type": "S", "description": "Worker instance ID" },
        "assignedAt": { "type": "S" },
        "workerHeartbeat": { "type": "S", "description": "Last heartbeat timestamp" },
        "startedAt": { "type": "S" },
        "completedAt": { "type": "S" },
        "timeoutAt": { "type": "S" },
        "executionResult": {
          "type": "M",
          "attributes": {
            "status": { "type": "S", "description": "success, failure, timeout" },
            "statusCode": { "type": "N", "description": "HTTP status for API jobs" },
            "responseSizeBytes": { "type": "N" },
            "errorDetails": {
              "type": "M",
              "attributes": {
                "code": { "type": "S" },
                "message": { "type": "S" },
                "stackTrace": { "type": "S" }
              }
            }
          }
        },
        "ttl": {
          "type": "N",
          "description": "Unix timestamp; TTL for cleanup ~48h after completion"
        }
      }
    },
    {
      "tableName": "WorkerNodes",
      "description": "Distributed execution worker registry",
      "keySchema": [
        { "attributeName": "workerId", "keyType": "HASH" },
        { "attributeName": "registeredAt", "keyType": "RANGE" }
      ],
      "attributes": {
        "workerId": { "type": "S" },
        "workerType": { "type": "S", "description": "primary, secondary, spot" },
        "instanceType": { "type": "S", "description": "AWS instance type" },
        "ipAddress": { "type": "S" },
        "availabilityZone": { "type": "S" },
        "maxConcurrentJobs": { "type": "N" },
        "currentJobCount": { "type": "N" },
        "totalJobsProcessed": { "type": "N" },
        "lastHeartbeat": { "type": "S" },
        "status": { "type": "S", "description": "healthy, degraded, unhealthy" },
        "cpuUtilization": { "type": "N" },
        "memoryUtilization": { "type": "N" },
        "supportedJobTypes": { "type": "SS", "description": "String set" },
        "tags": { "type": "M", "description": "Map of tags" },
        "registeredAt": { "type": "S" },
        "lastUpdatedAt": { "type": "S" }
      }
    }
  ]
}
