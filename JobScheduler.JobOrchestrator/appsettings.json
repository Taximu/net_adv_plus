{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Messaging": {
    "Consumers": {
      "Lifecycle": {
        "BootstrapServers": "localhost:19092",
        "GroupId": "job-orchestrator-lifecycle",
        "Topic": "execution.lifecycle",
        "AutoOffsetReset": "earliest"
      }
    }
  },
  "Orchestrator": {
    "Batch": {
      "ApiBaseUrl": "http://localhost:5000",
      "IntervalSeconds": 45,
      "PendingPeekLimit": 25
    }
  },
  "Database": {
    "PostgresWriteConnectionString": "Host=localhost;Port=5432;Database=job_config_db;Username=job_admin;Password=StrongP@ssw0rd",
    "PostgresReadConnectionStrings": [
      "Host=localhost;Port=5432;Database=job_config_db;Username=job_admin;Password=StrongP@ssw0rd"
    ]
  },
  "DynamoDB": {
    "Region": "us-east-1",
    "ServiceUrl": "http://localhost:8000",
    "AccessKeyId": "local",
    "SecretAccessKey": "local",
    "ExecutionQueueTableName": "ExecutionQueue",
    "WorkerNodesTableName": "WorkerNodes"
  }
}
