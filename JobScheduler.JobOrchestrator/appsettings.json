{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Messaging": {
    "Consumers": {
      "Lifecycle": {
        "BootstrapServers": "localhost:19092",
        "GroupId": "job-orchestrator-lifecycle",
        "Topic": "execution.lifecycle",
        "AutoOffsetReset": "earliest"
      }
    }
  },
  "Orchestrator": {
    "Batch": {
      "ApiBaseUrl": "http://localhost:5000",
      "IntervalSeconds": 45,
      "PendingPeekLimit": 25
    }
  }
}
